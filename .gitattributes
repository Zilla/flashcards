# Enforce LF line endings for all text/code files
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Enforce CRLF for Windows batch files (required for command prompt to execute them correctly)
*.bat text eol=crlf
